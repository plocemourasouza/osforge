{
  "_comment": "MCPs configurados no Cursor UI (Settings → MCP). Arquivo de referência/IaC — o Cursor não tem arquivo de config exportável. Para aplicar: configurar manualmente no Cursor UI ou via mcp.json na raiz do projeto.",
  "_last_updated": "2026-02-27",
  "mcpServers": {
    "Context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "Github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "Supabase": {
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase@latest"],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      }
    },
    "Shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    },
    "Browsermcp": {
      "command": "npx",
      "args": ["@browsermcp/mcp@latest"]
    }
  }
}
